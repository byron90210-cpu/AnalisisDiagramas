        <mxCell id="3Np7Tul7BnYxeEJvSTUr-68" parent="3Np7Tul7BnYxeEJvSTUr-67" style="text;html=1;whiteSpace=wrap;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;rounded=0;" value="El proceso de Screening se encuentra en AWS y producto es Gesintel. este recibe los documento del AS400 via SFTP, este SFTP se lanza cuando el OOBB hace un registro nuevo de cliente, primero revisa en gesintel si existe el cliente y carga la información que se tiene, este posterior genera una carga en el AS400 desde el OOBB via MQ para luego general al cliente como parte de BSP en gesintel" vertex="1">
          <mxGeometry height="30" width="160" x="10" y="23.5" as="geometry" />
        </mxCell>
