        <mxCell id="3Np7Tul7BnYxeEJvSTUr-62" parent="3Np7Tul7BnYxeEJvSTUr-61" style="text;html=1;whiteSpace=wrap;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;rounded=0;" value="Ofice Banking, pero la parte del BackEnd, ya que el front es el nuevo ebanking pero este se integra a travez del antiguo OOBB, es integra con el AS400 via MQ para la solicitudes de clientes y SFTP para la generación de archivos o evidencias" vertex="1">
          <mxGeometry height="23.5" width="160" x="10" y="30" as="geometry" />
        </mxCell>
        <mxCell id="3Np7Tul7BnYxeEJvSTUr-63" parent="3Np7Tul7BnYxeEJvSTUr-61" style="shape=curlyBracket;whiteSpace=wrap;html=1;rounded=1;labelPosition=left;verticalLabelPosition=middle;align=right;verticalAlign=middle;" value="" vertex="1">
