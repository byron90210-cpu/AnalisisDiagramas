          <mxGeometry height="30" width="160" x="10" y="23.5" as="geometry" />
        </mxCell>
        <mxCell id="3Np7Tul7BnYxeEJvSTUr-66" parent="3Np7Tul7BnYxeEJvSTUr-64" style="shape=curlyBracket;whiteSpace=wrap;html=1;rounded=1;labelPosition=left;verticalLabelPosition=middle;align=right;verticalAlign=middle;" value="" vertex="1">
